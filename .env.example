# Configurações do Banco de Dados
POSTGRES_DB=petmatch
POSTGRES_USER=petmatch
POSTGRES_PASSWORD=petmatch
POSTGRES_HOST_PORT=5432

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=petmatch
DATABASE_PASSWORD=petmatch
DATABASE_NAME=petmatch
DATABASE_SYNCHRONIZE=true
DATABASE_MIGRATIONS_RUN=false
DATABASE_LOGGING=false

# Se preferir DATABASE_URL, remova os campos DATABASE_* acima e use:
# DATABASE_URL=postgres://petmatch:petmatch@localhost:5432/petmatch
# DATABASE_SSL=false
# DATABASE_SSL_REJECT_UNAUTHORIZED=true

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-secret-here
JWT_REFRESH_EXPIRES_IN=30d

# Configurações da Aplicação
PORT=3000
NODE_ENV=development

# CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Upload de Arquivos
MAX_FILE_SIZE=5242880
UPLOAD_DEST=./uploads

# Email (opcional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
